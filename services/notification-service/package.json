{
    "name": "notification-service",
    "version": "1.0.0",
    "description": "Sends notifications when content jobs complete",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "studio": "dotenv -e ../../.env -- sh -c 'DATABASE_URL=$LOCAL_DATABASE_URL npx prisma studio'",
        "db:push": "dotenv -e ../../.env -- sh -c 'DATABASE_URL=$LOCAL_DATABASE_URL npx prisma db push'"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.21.0",
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "amqplib": "^1.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "prisma": "^5.22.0",
        "tsx": "^4.19.2",
        "uuid": "^13.0.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/amqplib": "^0.10.8",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.3.0",
        "dotenv-cli": "^11.0.0",
        "typescript": "^5.9.3"
    }
}